<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout affiché sur le petit écran dashboard (instrument cluster) du BYD Seal.
    Résolution typique : ~1920x720 — conserver un design épuré et lisible.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:padding="16dp">

    <!-- VITESSE — centre gauche, élément principal -->
    <LinearLayout
        android:id="@+id/block_speed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerVertical="true"
        android:layout_marginStart="40dp">

        <TextView
            android:id="@+id/dash_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="96sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-light"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="km/h"
            android:textColor="#888888"
            android:textSize="18sp"
            android:layout_gravity="end"/>
    </LinearLayout>

    <!-- RAPPORT / MODE — centre -->
    <TextView
        android:id="@+id/dash_gear"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="D"
        android:textColor="#00BCD4"
        android:textSize="72sp"
        android:textStyle="bold"
        android:layout_centerInParent="true"/>

    <!-- BATTERIE + AUTONOMIE — droite -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="40dp">

        <!-- Icône + % batterie -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ "
                android:textColor="#00BCD4"
                android:textSize="20sp"/>

            <TextView
                android:id="@+id/dash_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--%"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Autonomie restante -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↗ "
                android:textColor="#888888"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/dash_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- km"
                android:textColor="#AAAAAA"
                android:textSize="20sp"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
