<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D">

    <!-- En-tête -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A2E"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 BYD Live — Données véhicule"
            android:textColor="#90CAF9"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_live_perm_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initialisation…"
            android:textColor="#888888"
            android:textSize="11sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Grille de données BYD (polling 1 s) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="#111111">

        <!-- Vitesse -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#0D2040"
            android:padding="10dp"
            android:layout_marginEnd="5dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="VITESSE"
                android:textColor="#4A9FDF"
                android:textSize="9sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:id="@+id/tv_live_speed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-- km/h"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Rapport -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#0D200D"
            android:padding="10dp"
            android:layout_marginEnd="5dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RAPPORT"
                android:textColor="#4ADF8A"
                android:textSize="9sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:id="@+id/tv_live_gear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Mode énergie -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#201A0D"
            android:padding="10dp"
            android:layout_marginEnd="5dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MODE"
                android:textColor="#F0A040"
                android:textSize="9sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:id="@+id/tv_live_energy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Puissance regen -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1A0D20"
            android:padding="10dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="REGEN"
                android:textColor="#A04ADF"
                android:textSize="9sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:id="@+id/tv_live_powergen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-- kW"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Séparateur journal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#0A0A14"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Journal de bord en temps réel"
            android:textColor="#444444"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btn_live_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑 Effacer"
            android:textSize="11sp"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btn_live_share"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📤 Partager"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Journal scrollable -->
    <ScrollView
        android:id="@+id/scroll_live_log"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#050505">

        <TextView
            android:id="@+id/tv_live_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#00CC55"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:lineSpacingMultiplier="1.3"/>
    </ScrollView>

</LinearLayout>
