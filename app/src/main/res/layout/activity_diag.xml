<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Titre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Diagnostic de compatibilité"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vérifie quel mécanisme est disponible pour envoyer des apps sur l'écran dashboard (instrument cluster)."
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="20dp"/>

        <!-- ======================== TEST 1 ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 1 — Presentation API (méthode recommandée)"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Détecte si le cluster est exposé comme un display Android standard (DISPLAY_CATEGORY_PRESENTATION). C'est la méthode propre qui ne nécessite pas ADB."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_presentation_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="En attente du diagnostic…"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#333333"
            android:layout_marginBottom="20dp"/>

        <!-- ======================== TEST 2 ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 2 — Réflexion setLaunchDisplayId"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vérifie que ActivityOptions.setLaunchDisplayId() (méthode @hide AOSP) est accessible par réflexion Java à l'exécution. Nécessaire pour lancer n'importe quelle app tierce sur le display."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_reflection_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="En attente du diagnostic…"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#333333"
            android:layout_marginBottom="20dp"/>

        <!-- ======================== TEST 3 ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 3 — ADB TCP local (méthode Freedom)"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tente une connexion sur 127.0.0.1:5037 et 127.0.0.1:5555 pour savoir si le daemon ADB local est joignable. Nécessite 'Débogage sans fil' activé dans les paramètres développeur."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_adb_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="En attente du diagnostic…"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#333333"
            android:layout_marginBottom="24dp"/>

        <!-- ======================== TEST 4 ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 4 — Lancement effectif sur le cluster"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tente réellement de lancer les Paramètres Android sur le display secondaire via setLaunchDisplayId(). Confirme que toute la chaîne fonctionne sur ce véhicule précis. L'app apparaîtra momentanément sur le cluster."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_launch_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="En attente du diagnostic…"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#333333"
            android:layout_marginBottom="24dp"/>

        <!-- ======================== BOUTON ======================== -->
        <Button
            android:id="@+id/btn_run_diag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lancer le diagnostic"
            android:textSize="15sp"
            android:layout_marginBottom="24dp"/>

        <!-- ======================== CONCLUSION ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONCLUSION"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_conclusion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lancez le diagnostic pour voir la conclusion."
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="16dp"
            android:background="#333333"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
